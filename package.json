{
  "name": "@janv/streams",
  "version": "0.9.0",
  "description": "TypeScript stream utilities and operators",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/react/index.js",
      "types": "./dist/react/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/janv/streams.git"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.3.1",
    "@types/react": "^18.3.28",
    "jsdom": "^25.0.1",
    "prettier": "^3.6.2",
    "typescript": "^6.0.1-rc",
    "vitest": "^3.2.4"
  },
  "prettier": {},
  "peerDependencies": {
    "react": ">=16"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
